{
  "name": "sanova-rwa-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate --filter=@sanova/database",
    "db:push": "turbo db:push --filter=@sanova/database",
    "db:rwa-automation": "node scripts/apply-rwa-automation-migration.mjs",
    "db:stablecoin-payments": "node scripts/apply-stablecoin-payments-migration.mjs",
    "db:project-yield": "node scripts/apply-project-yield-migration.mjs",
    "vercel:check-payments": "node scripts/vercel/check-payments-env.mjs",
    "vercel:sync-payments": "node scripts/vercel/sync-payments-env.mjs",
    "vercel:sync-walletconnect": "node scripts/vercel/sync-walletconnect-env.mjs",
    "vercel:check-walletconnect": "node scripts/verify-walletconnect-setup.mjs",
    "verify:usdc-checkout": "node scripts/verify-usdc-checkout-ready.mjs",
    "verify:stripe-setup": "node scripts/verify-stripe-setup.mjs",
    "verify:morpho-borrow": "npx tsx scripts/verify-morpho-borrow-ready.ts",
    "yield:distribute": "npx tsx scripts/distribute-yield-batch.ts",
    "yield:pipeline": "npx tsx scripts/run-yield-pipeline.ts",
    "vercel:check-lending": "node scripts/vercel/check-lending-env.mjs",
    "vercel:check-morpho": "node scripts/vercel/check-morpho-env.mjs",
    "vercel:sync-lending": "node scripts/vercel/sync-lending-env.mjs",
    "db:seed": "npm run db:seed -w @sanova/database",
    "db:reset-users": "npm run db:reset-users -w @sanova/database",
    "contracts:compile": "turbo compile --filter=@sanova/contracts",
    "contracts:export-abis": "npm run export:abis -w @sanova/contracts",
    "contracts:test": "turbo test --filter=@sanova/contracts",
    "contracts:security-audit": "node scripts/audit-rwa-contracts.mjs",
    "contracts:audit-report": "node scripts/generate-rwa-audit-report.mjs",
    "web:dev": "npm run dev -w @sanova/web",
    "api:dev": "npm run dev -w @sanova/api",
    "infra:up": "docker compose up postgres redis -d",
    "infra:down": "docker compose down",
    "dev:all": "node scripts/dev-all.mjs",
    "i18n:translate": "tsx scripts/i18n/translate-from-es.mjs",
    "i18n:translate:fix": "tsx scripts/i18n/translate-from-es.mjs",
    "test:rwa-launch-flow": "tsx scripts/test-rwa-launch-flow.ts"
  },
  "devDependencies": {
    "translate-google": "^1.5.0",
    "tsx": "^4.22.3",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "@noble/hashes": "1.7.2",
    "@noble/curves": "1.9.7",
    "@scure/bip32": "1.6.2"
  },
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1",
    "docx": "^9.7.1",
    "google-translate-api-x": "^10.7.2"
  }
}
