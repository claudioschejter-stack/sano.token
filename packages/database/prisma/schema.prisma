datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum InvestorType {
  RETAIL
  INSTITUTIONAL
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SecondaryListingStatus {
  OPEN
  FILLED
  CANCELLED
}

enum InvestmentStatus {
  ACTIVE
  PENDING
  LIQUIDATED
}

enum PayoutStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentMethod {
  INTERNAL_BALANCE
  USDC_ONCHAIN
  LOCAL_RAIL
  BRIDGE
  TRANSAK
  RAMP
  STRIPE
  MERCADO_PAGO
  COINBASE
  CUSTODIAL_STABLECOIN
}

enum PaymentIntentStatus {
  PENDING
  REQUIRES_PAYMENT
  MANUAL_REVIEW
  CONFIRMED
  FAILED
  EXPIRED
  REFUNDED
}

enum StablecoinWalletType {
  EXTERNAL
  CUSTODIAL
  TREASURY
}

enum StablecoinWalletStatus {
  ACTIVE
  PENDING
  DISABLED
}

enum PlatformLedgerEntryType {
  DEPOSIT_CREDIT
  TOKEN_PURCHASE_DEBIT
  WITHDRAWAL_DEBIT
  REFUND_CREDIT
  RENT_CREDIT
  MANUAL_ADJUSTMENT
}

enum RentPayoutPreference {
  FIAT
  USDC
}

enum PlatformLedgerEntryStatus {
  PENDING
  POSTED
  REVERSED
}

enum PlatformDepositStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
  MANUAL_REVIEW
}

enum PlatformWithdrawalStatus {
  PENDING
  PROCESSING
  CONFIRMED
  FAILED
  CANCELLED
  MANUAL_REVIEW
}

enum PlatformWithdrawalMethod {
  STABLECOIN
  FIAT
}

enum ProjectOperatingEntryType {
  RENT_CREDIT
  CONVERSION_DEBIT
  MANUAL_ADJUSTMENT
}

enum ProjectYieldBatchStatus {
  QUEUED
  CONVERTING
  USDC_READY
  DISTRIBUTING
  COMPLETED
  FAILED
}

enum YieldConversionRail {
  BRIDGE
  COINBASE
  EXCHANGE
  MANUAL_USDC
}

enum FiscalRegime {
  LEY_19640
  GENERAL
}

enum AdvisorTier {
  JUNIOR
  SENIOR
  PARTNER
}

enum AdvisorNominationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TeamInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum AdvisorCategory {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum CommissionEventType {
  TOKEN_PURCHASE
  RENT_DISTRIBUTION
}

enum CommissionAccrualStatus {
  ACCRUED
  PAID
  CANCELLED
}

enum CommissionRecipientRole {
  ADVISOR
  ADVISOR_MANAGER
  PLATFORM_OPEX
  ADMIN_OPS
  PLATFORM_RESIDUAL
}

enum SystemRole {
  ADMIN
  ADVISOR_MANAGER
  ADVISOR
  INVESTOR
  TREASURY
  OPERATOR
}

enum AccountStatus {
  ONBOARDING
  OPERATIONAL
  SUSPENDED
}

enum VerificationChannel {
  EMAIL
  PHONE
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  phone             String?
  name              String?
  image             String?
  walletAddress     String?       @unique
  systemRole        SystemRole    @default(INVESTOR)
  passwordHash      String?
  oauthProvider     String?
  oauthProviderId   String?
  investorId        String?       @unique
  kycStatus         KycStatus     @default(PENDING)
  kycProviderId     String?
  kycFullName       String?
  kycDocumentId     String?
  kycDateOfBirth    String?
  kycNationality    String?
  kycDocumentType   String?
  kycDocumentExpiry String?
  kycGender         String?
  diditSessionId    String?
  emailVerifiedAt   DateTime?
  phoneVerifiedAt   DateTime?
  termsAcceptedAt   DateTime?
  investorAccessEnabled Boolean   @default(false)
  accountStatus     AccountStatus @default(ONBOARDING)
  jurisdiction      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  investor              Investor?              @relation(fields: [investorId], references: [id], onDelete: SetNull)
  portfolio             Portfolio?
  dividendDistributions DividendDistribution[]
  advisor               Advisor?
  reviewedNominations   AdvisorNomination[]    @relation("NominationReviewedBy")
  teamInvitesSent       TeamInvite[]           @relation("TeamInviteInvitedBy")
  verificationCodes     VerificationCode[]
  secondaryListingsSold SecondaryMarketListing[] @relation("SecondarySeller")
  secondaryListingsBought SecondaryMarketListing[] @relation("SecondaryBuyer")

  @@index([walletAddress])
  @@index([investorId])
  @@index([kycStatus])
  @@index([accountStatus])
  @@index([phone])
  @@index([jurisdiction])
}

model VerificationCode {
  id         String              @id @default(cuid())
  userId     String
  channel    VerificationChannel
  target     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel])
  @@index([expiresAt])
}

model Advisor {
  id                  String          @id @default(cuid())
  userId              String          @unique
  uplineId            String?
  tier                AdvisorTier     @default(JUNIOR)
  category            AdvisorCategory @default(BRONZE)
  categoryQualifiedAt DateTime?
  categoryEvaluatedAt DateTime?
  accumulatedVolume   Decimal         @default(0) @db.Decimal(20, 6)
  commissionRateBps   Int             @default(100)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  upline   Advisor?  @relation("AdvisorHierarchy", fields: [uplineId], references: [id], onDelete: SetNull)
  downline Advisor[] @relation("AdvisorHierarchy")

  incorporatedInvestors Investor[]            @relation("InvestorIncorporatedBy")
  nominationsSuggested  AdvisorNomination[]   @relation("NominationSuggestedBy")
  nominationsAsUpline     AdvisorNomination[]   @relation("NominationProposedUpline")
  teamInvites           TeamInvite[]
  commissionAccruals    CommissionAccrual[]

  @@index([uplineId])
  @@index([tier])
  @@index([category])
}

model AdvisorNomination {
  id                   String                  @id @default(cuid())
  email                String
  name                 String?
  suggestedByAdvisorId String
  proposedUplineId     String?
  status               AdvisorNominationStatus @default(PENDING)
  reviewedByUserId     String?
  reviewedAt           DateTime?
  rejectionReason      String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  suggestedBy    Advisor  @relation("NominationSuggestedBy", fields: [suggestedByAdvisorId], references: [id], onDelete: Cascade)
  proposedUpline Advisor? @relation("NominationProposedUpline", fields: [proposedUplineId], references: [id], onDelete: SetNull)
  reviewedBy     User?    @relation("NominationReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([suggestedByAdvisorId])
  @@index([email])
}

model TeamInvite {
  id              String           @id @default(cuid())
  email           String
  name            String?
  role            SystemRole
  uplineAdvisorId String?
  tokenHash       String           @unique
  status          TeamInviteStatus @default(PENDING)
  invitedByUserId String
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  invitedBy User     @relation("TeamInviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  upline    Advisor? @relation(fields: [uplineAdvisorId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
  @@index([expiresAt])
}

model Investor {
  id                 String       @id @default(cuid())
  email              String       @unique
  fullName           String
  cuit               String       @unique
  walletAddress      String       @unique
  investorType       InvestorType @default(RETAIL)
  kycStatus          KycStatus    @default(PENDING)
  kycVerifiedAt      DateTime?
  originOfFunds      String?
  brokerAccountRef     String?
  dividendPreference   String               @default("CASH")
  rentPayoutPreference RentPayoutPreference @default(FIAT)
  totalCapital         Decimal              @default(0) @db.Decimal(20, 6)
  marginDebt               Decimal      @default(0) @db.Decimal(20, 6)
  ltv                      Decimal      @default(0) @db.Decimal(8, 4)
  incorporatedByAdvisorId  String?
  incorporatedAt           DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  incorporatedBy        Advisor? @relation("InvestorIncorporatedBy", fields: [incorporatedByAdvisorId], references: [id], onDelete: SetNull)
  investments           Investment[]
  payoutReceipts        PayoutReceipt[]
  dividendDistributions DividendDistribution[]
  user                  User?

  @@index([kycStatus])
  @@index([walletAddress])
  @@index([brokerAccountRef])
  @@index([incorporatedByAdvisorId])
}

model Portfolio {
  id               String   @id @default(cuid())
  userId           String   @unique
  totalCapital     Decimal  @default(0) @db.Decimal(20, 6)
  activeMarginDebt Decimal  @default(0) @db.Decimal(20, 6)
  ltv              Decimal  @default(0) @db.Decimal(8, 4)
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id                   String       @id
  title                String
  description          String
  location             String
  image                String?
  latitude             Decimal?     @db.Decimal(10, 7)
  longitude            Decimal?     @db.Decimal(10, 7)
  mediaGallery         Json         @default("[]")
  contractTrustUrl     String?
  contractPurchaseUrl  String?
  contractLeaseUrl     String?
  contractSmartUrl     String?
  tokenName            String?
  tokenSymbol          String?
  tokenStandard        String       @default("SANOVA_KYC")
  tokenInstrumentType  String       @default("EQUITY")
  maturityDate         DateTime?
  equitySharePercent   Decimal?     @db.Decimal(8, 4)
  tokenDeployStatus    String       @default("NOT_REQUESTED")
  collateralTargets    Json         @default("[]")
  deploymentEvents     Json         @default("[]")
  centrifugeChecklist  Json         @default("{}")
  spvEntityName        String?
  navOracleUrl         String?
  totalTokens          Int
  availableTokens      Int
  pricePerToken        Decimal      @db.Decimal(20, 6)
  targetYield          Decimal      @db.Decimal(8, 4)
  fiscalRegime         FiscalRegime @default(LEY_19640)
  fiscalLawRef         String       @default("Ley 19.640")
  taxExemptionNote     String?
  jurisdiction         String?
  promoterEntity       String?
  contractAddress      String?
  usdcVaultAddress     String?
  vaultAddress         String?
  vaultFundingStatus   String       @default("NOT_REQUIRED")
  vaultFundingAmount   String?
  vaultFundingTxHash   String?
  vaultFundingError    String?
  chainId              Int?
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  investments Investment[]
  payouts     PayoutHistory[]
  secondaryListings SecondaryMarketListing[]
  operatingAccounts ProjectOperatingAccount[]
  yieldBatches      ProjectYieldBatch[]

  @@index([fiscalRegime])
  @@index([isActive])
  @@index([isActive, createdAt])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  action       String
  targetUserId String?
  projectId    String?
  metadata     Json     @default("{}")
  auditHash    String?
  createdAt    DateTime @default(now())

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([projectId])
  @@index([action])
  @@index([createdAt])
}

model InvestorAllowlist {
  id              String   @id @default(cuid())
  userId          String
  projectId       String
  walletAddress   String
  approved        Boolean  @default(false)
  txHash          String?
  chainId         Int?
  updatedByUserId String?
  auditHash       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([projectId, walletAddress])
  @@index([userId])
  @@index([projectId])
  @@index([walletAddress])
  @@index([approved])
}

model AutomationJob {
  id            String   @id @default(cuid())
  projectId     String?
  step          String
  status        String   @default("QUEUED")
  attempts      Int      @default(0)
  maxAttempts   Int      @default(3)
  runAfter      DateTime @default(now())
  lockedAt      DateTime?
  lockedBy      String?
  payload       Json     @default("{}")
  result        Json?
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
  @@index([step])
  @@index([status])
  @@index([runAfter])
  @@index([lockedAt])
}

model Investment {
  id               String           @id @default(cuid())
  investorId       String
  projectId        String
  tokenCount       Int
  purchasePriceUsd Decimal          @db.Decimal(20, 6)
  status           InvestmentStatus @default(PENDING)
  txHash           String?
  purchasedAt      DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([investorId, projectId, txHash])
  @@index([investorId])
  @@index([projectId])
  @@index([status])
  @@index([purchasedAt])
}

model PaymentIntent {
  id                  String              @id @default(cuid())
  userId              String
  investorId          String?
  projectId           String
  investmentId        String?
  method              PaymentMethod
  status              PaymentIntentStatus @default(PENDING)
  tokenCount          Int
  amountUsd           Decimal             @db.Decimal(20, 6)
  currency            String              @default("USD")
  stablecoinSymbol    String?
  chainId             Int?
  payerWalletAddress  String?
  payToAddress        String?
  txHash              String?
  provider            String?
  providerPaymentId   String?
  providerCheckoutUrl String?
  idempotencyKey      String?
  expiresAt           DateTime
  confirmedAt         DateTime?
  metadata            Json                @default("{}")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([userId])
  @@index([investorId])
  @@index([projectId])
  @@index([investmentId])
  @@index([method])
  @@index([status])
  @@index([expiresAt])
  @@index([provider, providerPaymentId])
}

model PaymentEvent {
  id              String   @id @default(cuid())
  paymentIntentId String
  type            String
  provider        String?
  txHash          String?
  payload         Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([paymentIntentId])
  @@index([type])
  @@index([provider])
  @@index([txHash])
  @@index([createdAt])
}

model StablecoinWallet {
  id         String                 @id @default(cuid())
  userId     String?
  investorId String?
  address    String                 @unique
  chainId    Int
  type       StablecoinWalletType   @default(EXTERNAL)
  status     StablecoinWalletStatus @default(ACTIVE)
  label      String?
  provider   String?
  metadata   Json                   @default("{}")
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([userId])
  @@index([investorId])
  @@index([chainId])
  @@index([type])
  @@index([status])
}

model PlatformWalletAccount {
  id        String   @id @default(cuid())
  userId    String
  investorId String?
  currency  String   @default("USD")
  balance   Decimal  @default(0) @db.Decimal(20, 6)
  reserved  Decimal  @default(0) @db.Decimal(20, 6)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, currency])
  @@index([userId])
  @@index([investorId])
  @@index([status])
}

model PlatformWalletLedgerEntry {
  id             String                    @id @default(cuid())
  accountId      String
  userId         String
  investorId     String?
  type           PlatformLedgerEntryType
  status         PlatformLedgerEntryStatus @default(POSTED)
  amount         Decimal                   @db.Decimal(20, 6)
  currency       String                    @default("USD")
  balanceAfter   Decimal                   @db.Decimal(20, 6)
  idempotencyKey String                    @unique
  paymentIntentId String?
  depositId      String?
  investmentId   String?
  txHash         String?
  metadata       Json                      @default("{}")
  createdAt      DateTime                  @default(now())

  @@index([accountId])
  @@index([userId])
  @@index([investorId])
  @@index([type])
  @@index([status])
  @@index([paymentIntentId])
  @@index([depositId])
  @@index([investmentId])
  @@index([txHash])
  @@index([createdAt])
}

model PlatformDeposit {
  id                  String                @id @default(cuid())
  userId              String
  investorId          String?
  status              PlatformDepositStatus @default(PENDING)
  amountUsd           Decimal               @db.Decimal(20, 6)
  currency            String                @default("USD")
  method              PaymentMethod
  stablecoinNetwork   String?
  stablecoinSymbol    String?
  payerWalletAddress  String?
  payToAddress        String?
  txHash              String?
  provider            String?
  providerPaymentId   String?
  providerCheckoutUrl String?
  idempotencyKey      String?
  expiresAt           DateTime
  confirmedAt         DateTime?
  metadata            Json                  @default("{}")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([userId])
  @@index([investorId])
  @@index([status])
  @@index([method])
  @@index([expiresAt])
  @@index([provider, providerPaymentId])
}

model PlatformWithdrawal {
  id                  String                   @id @default(cuid())
  userId              String
  investorId          String?
  status              PlatformWithdrawalStatus @default(PENDING)
  method              PlatformWithdrawalMethod
  amountUsd           Decimal                  @db.Decimal(20, 6)
  currency            String                   @default("USD")
  stablecoinNetwork   String?
  destinationAddress  String?
  txHash              String?
  provider            String?
  providerPaymentId   String?
  providerCheckoutUrl String?
  idempotencyKey      String?
  metadata            Json                     @default("{}")
  confirmedAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([userId])
  @@index([investorId])
  @@index([status])
  @@index([method])
  @@index([provider, providerPaymentId])
}

model ProjectOperatingAccount {
  id        String   @id @default(cuid())
  projectId String
  currency  String
  balance   Decimal  @default(0) @db.Decimal(20, 6)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ledger  ProjectOperatingLedgerEntry[]

  @@unique([projectId, currency])
  @@index([projectId])
  @@index([currency])
}

model ProjectOperatingLedgerEntry {
  id             String                    @id @default(cuid())
  accountId      String
  projectId      String
  type           ProjectOperatingEntryType
  amount         Decimal                   @db.Decimal(20, 6)
  currency       String
  balanceAfter   Decimal                   @db.Decimal(20, 6)
  idempotencyKey String                    @unique
  batchId        String?
  metadata       Json                      @default("{}")
  createdAt      DateTime                  @default(now())

  account ProjectOperatingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  batch   ProjectYieldBatch?      @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([projectId])
  @@index([type])
  @@index([batchId])
  @@index([createdAt])
}

model ProjectYieldBatch {
  id                String                   @id @default(cuid())
  projectId         String
  status            ProjectYieldBatchStatus  @default(QUEUED)
  sourceCurrency    String
  sourceAmount      Decimal                  @db.Decimal(20, 6)
  usdcAmount        Decimal?                 @db.Decimal(20, 6)
  conversionRail    YieldConversionRail?
  conversionRef     String?
  conversionTxHash  String?
  distributionTxHash String?                 @unique
  vaultAddress      String?
  chainId           Int?
  error             String?
  metadata          Json                     @default("{}")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  completedAt       DateTime?

  project Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ledger  ProjectOperatingLedgerEntry[]

  @@index([projectId])
  @@index([status])
  @@index([conversionRail])
  @@index([createdAt])
}

model PortfolioSnapshot {
  id              String   @id @default(cuid())
  userId          String
  investorId      String?
  baseCurrency    String   @default("USD")
  totalValueUsd   Decimal  @db.Decimal(20, 6)
  rwaValueUsd     Decimal  @default(0) @db.Decimal(20, 6)
  stablecoinUsd   Decimal  @default(0) @db.Decimal(20, 6)
  fiatUsd         Decimal  @default(0) @db.Decimal(20, 6)
  availableUsd    Decimal  @default(0) @db.Decimal(20, 6)
  debtUsd         Decimal  @default(0) @db.Decimal(20, 6)
  ltv             Decimal  @default(0) @db.Decimal(8, 4)
  positions       Json     @default("[]")
  capturedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([investorId])
  @@index([capturedAt])
  @@unique([userId, capturedAt])
}

model PayoutHistory {
  id              String       @id @default(cuid())
  projectId       String
  totalAmountPaid Decimal      @db.Decimal(20, 6)
  txHash          String       @unique
  status          PayoutStatus @default(PENDING)
  debtOffsetUsd   Decimal      @default(0) @db.Decimal(20, 6)
  liquidPaidUsd   Decimal      @default(0) @db.Decimal(20, 6)
  executedAt      DateTime     @default(now())

  project  Project         @relation(fields: [projectId], references: [id])
  receipts PayoutReceipt[]

  @@index([projectId])
  @@index([status])
  @@index([executedAt])
}

model PayoutReceipt {
  id               String  @id @default(cuid())
  payoutHistoryId  String
  investorId       String
  amountReceived   Decimal @db.Decimal(20, 6)
  debtCancelledUsd Decimal @default(0) @db.Decimal(20, 6)
  walletSentTo     String

  payout   PayoutHistory @relation(fields: [payoutHistoryId], references: [id], onDelete: Cascade)
  investor Investor      @relation(fields: [investorId], references: [id])

  @@index([payoutHistoryId])
  @@index([investorId])
}

model DividendDistribution {
  id              String    @id @default(uuid())
  assetId         String
  userId          String
  platformUserId  String?
  amount          Decimal   @db.Decimal(20, 6)
  appliedAmount   Decimal   @default(0) @db.Decimal(20, 6)
  currency        String    @default("USD")
  txHash          String?   @unique
  distributedAt   DateTime  @default(now())
  status          String
  appliedToMargin Boolean   @default(false)
  appliedAt       DateTime?

  investor Investor @relation(fields: [userId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [platformUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([platformUserId])
  @@index([assetId])
}

model BlockchainEvent {
  id              String   @id @default(cuid())
  txHash          String
  eventName       String
  contractAddress String
  payload         Json?
  processedAt     DateTime @default(now())

  @@unique([txHash, eventName, contractAddress])
  @@index([eventName])
  @@index([contractAddress])
  @@index([processedAt])
  @@index([txHash])
}

model PlatformConfig {
  id            String   @id @default("default")
  whatsappPhone String?
  contactEmail  String?
  siteUrl       String?
  updatedAt     DateTime @updatedAt
}

model PlatformCommissionPolicy {
  id                    String   @id @default(cuid())
  version               Int      @default(1)
  name                  String   @default("Política principal")
  isActive              Boolean  @default(false)
  effectiveFrom         DateTime @default(now())
  purchaseFeeBps        Int      @default(200)
  rentFeeBps            Int      @default(100)
  platformOpexShareBps  Int      @default(2500)
  adminOpsShareBps      Int      @default(3500)
  advisorPoolShareBps   Int      @default(4000)
  advisorDirectShareBps Int      @default(5000)
  managerShareBps       Int      @default(3000)
  platformResidualBps   Int      @default(2000)
  createdByUserId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  categoryRules      AdvisorCategoryRule[]
  commissionAccruals CommissionAccrual[]

  @@index([isActive])
  @@index([effectiveFrom])
}

model AdvisorCategoryRule {
  id                     String          @id @default(cuid())
  policyId               String
  category               AdvisorCategory
  sortOrder              Int             @default(0)
  minBookAumUsd          Decimal         @default(0) @db.Decimal(20, 6)
  minActiveInvestors     Int             @default(1)
  minQualifyingDays      Int             @default(0)
  advisorMultiplierBps   Int             @default(10000)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  policy PlatformCommissionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, category])
  @@index([policyId, sortOrder])
}

model CommissionAccrual {
  id              String                  @id @default(cuid())
  policyId        String
  eventType       CommissionEventType
  status          CommissionAccrualStatus @default(ACCRUED)
  grossAmountUsd  Decimal                 @db.Decimal(20, 6)
  feeAmountUsd    Decimal                 @db.Decimal(20, 6)
  investorId      String?
  advisorId       String?
  projectId       String?
  investmentId    String?
  recipientRole   CommissionRecipientRole
  recipientUserId String?
  amountUsd       Decimal                 @db.Decimal(20, 6)
  idempotencyKey  String                  @unique
  metadata        Json                    @default("{}")
  createdAt       DateTime                @default(now())
  paidAt          DateTime?

  policy  PlatformCommissionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  advisor Advisor?                 @relation(fields: [advisorId], references: [id], onDelete: SetNull)

  @@index([policyId])
  @@index([eventType])
  @@index([status])
  @@index([advisorId])
  @@index([investorId])
  @@index([projectId])
  @@index([createdAt])
}

model SecondaryMarketListing {
  id               String                 @id @default(cuid())
  sellerUserId     String
  projectId        String
  tokenCount       Int
  pricePerTokenUsd Decimal                @db.Decimal(20, 6)
  status           SecondaryListingStatus @default(OPEN)
  buyerUserId      String?
  txHash           String?
  filledAt         DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  sellerUser User    @relation("SecondarySeller", fields: [sellerUserId], references: [id], onDelete: Cascade)
  buyerUser  User?   @relation("SecondaryBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([sellerUserId, status])
  @@index([status, createdAt])
}
